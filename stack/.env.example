# ============================================================
# Secure SIP & WebRTC Platform - Environment Configuration
# Copy this file to .env and fill in your values before
# running docker compose up.
# ============================================================

# -----------------------------------------------------------
# SERVER IDENTITY
# The public IP of this server. Used in SIP contact headers,
# RTPengine, and coturn.
# -----------------------------------------------------------
PUBLIC_IP=203.0.113.10

# Domain name for TLS/WSS (optional - leave blank to use IP)
# If set, certificates are expected at certs/fullchain.pem + privkey.pem
DOMAIN=sip.example.com

# -----------------------------------------------------------
# SIP CREDENTIALS
# Change all passwords before deploying.
# -----------------------------------------------------------
SIP_REALM=example.com

# Test accounts (alice and bob) - remove or change in production
ALICE_PASS=changeme_alice
BOB_PASS=changeme_bob

# Admin account for Asterisk Manager Interface (AMI)
AMI_USER=admin
AMI_PASS=changeme_ami

# -----------------------------------------------------------
# KAMAILIO
# -----------------------------------------------------------
# Kamailio database connection (internal MySQL)
KAMAILIO_DB_HOST=mysql
KAMAILIO_DB_PORT=3306
KAMAILIO_DB_USER=kamailio
KAMAILIO_DB_PASS=changeme_db
KAMAILIO_DB_NAME=kamailio

# Anti-flood: max requests per second per IP before auto-ban
PIKE_SAMPLE_TIME=2
PIKE_REQS_LIMIT=20
PIKE_REMOVE_LATENCY=4

# Registration rate limit: max REGISTER per minute per AOR
REG_RATE_LIMIT=5

# Failed auth bans (number of failures before IP ban)
AUTH_FAIL_LIMIT=5
AUTH_BAN_TTL=3600

# -----------------------------------------------------------
# RTPENGINE
# RTP port range opened on the firewall
# -----------------------------------------------------------
RTP_MIN_PORT=20000
RTP_MAX_PORT=30000

# -----------------------------------------------------------
# COTURN
# TURN shared secret (used for time-limited credentials)
# -----------------------------------------------------------
TURN_SECRET=changeme_turn_secret
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535

# -----------------------------------------------------------
# MYSQL (internal subscriber database)
# -----------------------------------------------------------
MYSQL_ROOT_PASS=changeme_mysql_root
MYSQL_USER=kamailio
MYSQL_PASS=changeme_db
MYSQL_DATABASE=kamailio

# -----------------------------------------------------------
# REDIS (shared state for rate limiting and bans)
# -----------------------------------------------------------
REDIS_PASS=changeme_redis

# -----------------------------------------------------------
# CARRIER TRUNKS
# Add your carrier SIP trunk details here.
# Never commit real credentials.
# -----------------------------------------------------------
CARRIER_TRUNK_HOST=trunk.carrier.example.com
CARRIER_TRUNK_USER=your_trunk_user
CARRIER_TRUNK_PASS=changeme_trunk
CARRIER_TRUNK_MAX_CALLS=50
